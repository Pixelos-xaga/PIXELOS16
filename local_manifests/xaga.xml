<?xml version="1.0" encoding="UTF-8"?>
<!--
  Local manifest for PixelOS Xaga build
  Uses device trees and vendor blobs from XagaForge
  
  Place this file in: .repo/local_manifests/xaga.xml
-->
<manifest>

  <remote name="github"
          fetch="https://github.com/" />
  
  <remote name="gitlab"
          fetch="https://gitlab.com/" />

  <!-- Device Trees (LineageOS 23.1 / Android 16) -->
  <project name="xiaomi-mt6895-devs/android_device_xiaomi_xaga"
           path="device/xiaomi/xaga"
           remote="github"
           revision="lineage-23.1" />

  <project name="xiaomi-mt6895-devs/android_device_xiaomi_mt6895-common"
           path="device/xiaomi/mt6895-common"
           remote="github"
           revision="lineage-23.1" />

  <!-- Vendor -->
  <project name="xiaomi-mt6895-devs/proprietary_vendor_xiaomi_xaga"
           path="vendor/xiaomi/xaga"
           remote="github"
           revision="lineage-23.1" />

  <project name="xiaomi-mt6895-devs/proprietary_vendor_xiaomi_mt6895-common"
           path="vendor/xiaomi/mt6895-common"
           remote="github"
           revision="lineage-23.1" />

  <!-- Kernel -->
  <project name="xiaomi-mt6895-devs/android_kernel_xiaomi_mt6895"
           path="kernel/xiaomi/mt6895"
           remote="github"
           revision="lineage-23.1" />

  <!-- Hardware/MediaTek -->
  <project name="xiaomi-mt6895-devs/android_hardware_mediatek"
           path="hardware/mediatek"
           remote="github"
           revision="lineage-23.1" />

  <project name="xiaomi-mt6895-devs/android_device_mediatek_sepolicy-vndr"
           path="device/mediatek/sepolicy_vndr"
           remote="github"
           revision="lineage-23.1" />

  <!-- Firmware (XagaForge/Other) - Commented out if unsure, or use known -->
  <!-- 
  <project name="android_vendor_xiaomi_xaga-firmware"
           path="vendor/xiaomi/xaga-firmware"
           remote="xaga"
           revision="sixteen" />
  -->

  <!-- MIUI Camera (GitLab source found in fixes.sh) -->
  <project name="priiii1808/proprietary_vendor_xiaomi_miuicamera-xaga"
           path="vendor/xiaomi/miuicamera-xaga"
           remote="gitlab"
           revision="16.1" />

</manifest>
